
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.email == 'care-rc@firstlighthomecare.com';
    }

    function isOwner() {
      return request.auth.token.email == 'lpinto@firstlighthomecare.com';
    }

    function isStaffingAdmin() {
      return request.auth.token.email == 'admin-rc@firstlighthomecare.com';
    }

    function isAnyAdmin() {
        return request.auth != null && (isAdmin() || isOwner() || isStaffingAdmin());
    }

    match /caregiver_profiles/{profileId} {
      allow read, write: if isSignedIn();
       match /signatures/{docId} {
        allow read, write: if isSignedIn() && (request.auth.uid == profileId || isAnyAdmin());
      }
    }

    match /appointments/{appointmentId} {
      allow read, write: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /interviews/{interviewId} {
      allow get: if isSignedIn();
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    match /caregiver_employees/{employeeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
   
    match /Clients/{clientId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
    match /caregivers_active/{caregiverId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if isSignedIn();
    match /availability/{weekId} {
        allow get, list, read: if true;
        allow write: if isAnyAdmin();
    	}
    match /preferences/{docId} {
        allow get, list, read: if true;
        allow write: if isAnyAdmin();
      }
    }
    match /carelog_groups/{carelogId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if isSignedIn();
    }
    match /carelogs/{logId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }
    match /client_additional_care_requests/{requestId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAnyAdmin();
    }
    match /carelog_templates/{templateId} {
      allow get, list: if true;
      allow create: if isAnyAdmin();
      allow update, delete: if isAnyAdmin();
    }
     match /va_task_templates/{templateId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }
    match /client_signups/{signupsId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAnyAdmin();
    }
    match /initial_contacts/{initialContactId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAnyAdmin();
    }
    match /video_checkin_requests/{videoCheckinRequestId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAnyAdmin();
    }
    match /rewards/{rewardsId} {
      allow get, list: if true;
      allow create, update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }
    match /referrals/{referralsId} {
      allow get, list: if true;
      allow create, update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }
    match /referral_profiles/{profileId} {
      allow get, list: if true;
      allow create, update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }
    match /campaign_templates/{campaignTemplatesId} {
      allow get, list: if true;
      allow create, update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }
    match /level_of_care_assessments/{assessmentsId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAnyAdmin();
    }
    match /initial_contacts/{initialContactId}/sms_history/{smsHistoryId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAnyAdmin();
    }
    match /mail/{mailId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAnyAdmin();
    }
    match /caregiver_availability/{Id} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAnyAdmin();
    }

    match /va_teletrack_shifts/{shiftId} {
      allow get, list: if isAnyAdmin();
      allow create: if true;
      allow update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }

    // Calloff Inventory rules
    match /teletrack_weekly_shifts_inventory/{docId} {
      allow read: if isAnyAdmin();
      allow create: if true; // Allow cron job
    }
    match /teletrack_calloff_weekly_caregivers_list/{docId} {
      allow read: if isAnyAdmin();
      allow create: if true; // Allow cron job
    }

    // Unassigned Shifts rules
    match /teletrack_weekly_unassigned_shifts_inventory/{docId} {
      allow read: if isAnyAdmin();
      allow create: if true; // Allow cron job
    }
    match /teletrack_unassigned_weekly_caregivers_list/{docId} {
      allow read: if isAnyAdmin();
      allow create: if true; // Allow cron job
    }
  }
}
